<odoo>
    <record id="module_category_estate" model="ir.module.category">
        <field name="name">Estate</field>
        <field name="description">Estate management access levels</field>
        <field name="sequence">30</field>
    </record>

    <record id="group_estate_user" model="res.groups">
        <field name="name">Estate Agent</field>
        <field name="category_id" ref="estate.module_category_estate" />
    </record>

    <record id="group_estate_manager" model="res.groups">
        <field name="name">Estate Manager</field>
        <field name="category_id" ref="estate.module_category_estate" />
        <field name="implied_ids" eval="[(4, ref('estate.group_estate_user'))]" />
        <field name="users" eval="[(4, ref('base.user_admin'))]" />
    </record>

    <record id="estate_property_rule_agent_own" model="ir.rule">
        <field name="name">Estate property: agent own records</field>
        <field name="model_id" ref="model_estate_property" />
        <field name="groups" eval="[(4, ref('estate.group_estate_user'))]" />
        <field name="domain_force">[('salesperson_id', '=', user.id)]</field>
    </record>

    <record id="estate_offer_rule_agent_own" model="ir.rule">
        <field name="name">Estate offer: agent own records</field>
        <field name="model_id" ref="model_estate_property_offer" />
        <field name="groups" eval="[(4, ref('estate.group_estate_user'))]" />
        <field name="domain_force">[('property_id.salesperson_id', '=', user.id)]</field>
    </record>

    <record id="estate_property_rule_manager_all" model="ir.rule">
        <field name="name">Estate property: manager all records</field>
        <field name="model_id" ref="model_estate_property" />
        <field name="groups" eval="[(4, ref('estate.group_estate_manager'))]" />
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="estate_offer_rule_manager_all" model="ir.rule">
        <field name="name">Estate offer: manager all records</field>
        <field name="model_id" ref="model_estate_property_offer" />
        <field name="groups" eval="[(4, ref('estate.group_estate_manager'))]" />
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
