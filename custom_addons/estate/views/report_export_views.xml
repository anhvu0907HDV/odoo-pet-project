<odoo>
    <record id="view_estate_report_wizard_form" model="ir.ui.view">
        <field name="name">estate.report.wizard.form</field>
        <field name="model">estate.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Export Estate Report" class="o_estate_report_wizard_form">
                <sheet>
                    <div class="o_estate_report_intro">
                        <h2>Smart Report Export</h2>
                        <p class="text-muted">Generate polished PDF or Excel reports with filters tailored for your interview demo.</p>
                    </div>
                    <group>
                        <group>
                            <field name="state" />
                            <field name="property_type_id" />
                            <field name="include_archived" />
                        </group>
                        <group>
                            <field name="date_from" />
                            <field name="date_to" />
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Export PDF"
                        type="object"
                        name="action_export_pdf"
                        class="btn-primary o_estate_btn o_estate_btn_ai_main" />
                    <button string="Export Excel"
                        type="object"
                        name="action_export_xlsx"
                        class="btn-secondary o_estate_btn o_estate_btn_stat" />
                    <button string="Close" special="cancel" class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_estate_report_wizard" model="ir.actions.act_window">
        <field name="name">Export Reports</field>
        <field name="res_model">estate.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
