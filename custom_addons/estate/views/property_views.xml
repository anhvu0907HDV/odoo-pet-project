<odoo>
    <record id="view_property_tree" model="ir.ui.view">
        <field name="name">estate.property.tree</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <tree string="Properties">
                <field name="name" />
                <field name="price" />
                <field name="best_price" />
                <field name="bedrooms" />
                <field name="salesperson_id" />
                <field name="buyer_id" />
                <field name="state" />
            </tree>
        </field>
    </record>

    <record id="view_property_kanban" model="ir.ui.view">
        <field name="name">estate.property.kanban</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name" />
                <field name="price" />
                <field name="best_price" />
                <field name="bedrooms" />
                <field name="state" />

                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <strong>
                                <field name="name" />
                            </strong>

                            <div>
                                Expected: <field name="price" />
                            </div>
                            <div>
                                Best offer: <field name="best_price" />
                            </div>
                            <div>
                                Bedrooms: <field name="bedrooms" />
                            </div>
                            <div>
                                Status: <field name="state" />
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_property_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form string="Property">
                <header>
                    <button name="action_mark_sold"
                        type="object"
                        string="Mark as Sold"
                        class="btn-primary"
                        invisible="state in ['sold', 'cancel']" />

                    <button name="action_cancel"
                        type="object"
                        string="Cancel"
                        class="btn-secondary"
                        invisible="state in ['sold', 'cancel']" />

                    <field name="state" widget="statusbar" statusbar_visible="new,offer,sold,cancel" />
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object"
                            name="action_view_offers"
                            class="oe_stat_button">
                            <field name="offer_count" widget="statinfo" string="Offers" />
                        </button>
                    </div>

                    <group>
                        <group>
                            <field name="name" />
                            <field name="price" />
                            <field name="bedrooms" />
                            <field name="salesperson_id" />
                            <field name="buyer_id" readonly="1" />
                        </group>
                        <group>
                            <field name="living_area" />
                            <field name="garden_area" />
                            <field name="total_area" readonly="1" />
                            <field name="best_price" readonly="1" />
                            <field name="company_id" groups="base.group_multi_company" />
                            <field name="active" />
                        </group>
                    </group>
                    <group>
                        <field name="description" />
                    </group>

                    <notebook>
                    <page string="Offers">
                        <field name="offer_ids" context="{'default_property_id': id}">
                            <tree editable="bottom" create="1" delete="0">
                                <field name="price" />
                                <field name="partner_id" />
                                <field name="validity" />
                                <field name="deadline" />
                                <field name="state" />
                            </tree>
                        </field>
                    </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>
</odoo>
