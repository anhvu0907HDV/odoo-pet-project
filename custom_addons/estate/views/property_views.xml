<odoo>

    <!-- ===================== -->
    <!-- KANBAN VIEW -->
    <!-- ===================== -->
    <record id="view_property_kanban" model="ir.ui.view">
        <field name="name">estate.property.kanban</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name" />
                <field name="price" />
                <field name="bedrooms" />
                <field name="state" />

                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">

                            <strong>
                                <field name="name" />
                            </strong>

                            <div> Price: <field name="price" />
                            </div>

                            <div> Bedrooms: <field name="bedrooms" />
                            </div>

                            <div> Status: <field name="state" />
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ===================== -->
    <!-- FORM VIEW -->
    <!-- ===================== -->
    <record id="view_property_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form string="Property">

                <!-- HEADER -->
                <header>
                    <button name="action_mark_sold"
                        type="object"
                        string="Mark as Sold"
                        class="btn-primary" />

                    <button name="action_cancel"
                        type="object"
                        string="Cancel"
                        class="btn-secondary" />

                    <field name="state" widget="statusbar" />
                </header>

                <sheet>

                    <!-- SMART BUTTON -->
                    <div class="oe_button_box" name="button_box">

                        <button type="object"
                            name="action_view_offers"
                            class="oe_stat_button">

                            <div class="o_stat_info">
                                <field name="offer_count" class="o_stat_value" />
                                <span class="o_stat_text">Offers</span>
                            </div>

                        </button>

                    </div>

                    <!-- MAIN INFO -->
                    <group>
                        <field name="name" />
                        <field name="price" />
                        <field name="bedrooms" />
                        <field name="living_area" />
                        <field name="garden_area" />
                        <field name="total_area" readonly="1" />
                        <field name="best_price" readonly="1" />
                        <field name="buyer_id" />
                        <field name="description" />
                    </group>

                </sheet>

                <!-- OFFERS -->
                <notebook>
                    <page string="Offers">
                        <field name="offer_ids">
                            <tree>
                                <field name="price" />
                                <field name="partner_id" />
                                <field name="state" />
                            </tree>
                        </field>
                    </page>
                </notebook>

                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>
    
</odoo>