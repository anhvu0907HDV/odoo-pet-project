<odoo>
    <record id="view_property_tree" model="ir.ui.view">
        <field name="name">estate.property.tree</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <tree string="Properties"
                class="o_estate_property_tree"
                decoration-info="state == 'offer'"
                decoration-success="state == 'sold'"
                decoration-muted="state == 'cancel'">
                <field name="name" />
                <field name="property_type_id" />
                <field name="currency_id" invisible="1" />
                <field name="expected_price" widget="monetary" options="{'currency_field': 'currency_id'}" />
                <field name="selling_price" widget="monetary" options="{'currency_field': 'currency_id'}" />
                <field name="best_price" widget="monetary" options="{'currency_field': 'currency_id'}" />
                <field name="salesperson_id" />
                <field name="state" />
            </tree>
        </field>
    </record>

    <record id="view_property_kanban" model="ir.ui.view">
        <field name="name">estate.property.kanban</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile o_estate_property_kanban">
                <field name="name" />
                <field name="property_type_id" />
                <field name="tag_ids" />
                <field name="expected_price" />
                <field name="selling_price" />
                <field name="best_price" />
                <field name="bedrooms" />
                <field name="total_area" />
                <field name="offer_count" />
                <field name="salesperson_id" />
                <field name="active" />
                <field name="currency_id" />
                <field name="state" />

                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_estate_property_card"
                            t-attf-class="o_estate_property_state_#{record.state.raw_value}"
                            t-att-class="{'o_estate_property_card_archived': !record.active.raw_value}">
                            <div class="o_estate_property_header">
                                <strong class="o_estate_property_title">
                                    <field name="name" />
                                </strong>
                                <span t-if="record.state.raw_value == 'new'" class="badge rounded-pill text-bg-primary">New</span>
                                <span t-if="record.state.raw_value == 'offer'" class="badge rounded-pill text-bg-info">Offer</span>
                                <span t-if="record.state.raw_value == 'sold'" class="badge rounded-pill text-bg-success">Sold</span>
                                <span t-if="record.state.raw_value == 'cancel'" class="badge rounded-pill text-bg-danger">Cancelled</span>
                            </div>

                            <div class="o_estate_property_subtitle">
                                <i class="fa fa-building me-1" />
                                <field name="property_type_id" />
                            </div>

                            <div class="o_estate_property_prices">
                                <div class="o_estate_metric">
                                    <span class="o_estate_metric_label">Expected</span>
                                    <span class="o_estate_metric_value">
                                        <field name="expected_price" widget="monetary" options="{'currency_field': 'currency_id'}" />
                                    </span>
                                </div>
                                <div class="o_estate_metric">
                                    <span class="o_estate_metric_label">Selling</span>
                                    <span class="o_estate_metric_value">
                                        <field name="selling_price" widget="monetary" options="{'currency_field': 'currency_id'}" />
                                    </span>
                                </div>
                            </div>

                            <div class="o_estate_property_meta">
                                <span><i class="fa fa-bed me-1" /> <field name="bedrooms" /> beds</span>
                                <span><i class="fa fa-home me-1" /> <field name="total_area" /> m2</span>
                            </div>

                            <div class="o_estate_property_footer">
                                <span><i class="fa fa-user me-1" /> <field name="salesperson_id" /></span>
                                <span><i class="fa fa-tag me-1" /> <field name="offer_count" /> offers</span>
                            </div>

                            <div class="o_estate_property_tags">
                                <field name="tag_ids" widget="many2many_tags" />
                            </div>

                            <div t-if="!record.active.raw_value" class="o_estate_archived_badge">Archived</div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_property_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form string="Property" class="o_estate_property_form">
                <header>
                    <button name="action_mark_sold"
                        type="object"
                        string="Mark as Sold"
                        class="btn-primary o_estate_btn o_estate_btn_sold"
                        groups="estate.group_estate_manager"
                        invisible="state in ['sold', 'cancel']" />

                    <button name="action_cancel"
                        type="object"
                        string="Cancel"
                        class="btn-secondary o_estate_btn o_estate_btn_cancel"
                        groups="estate.group_estate_manager"
                        invisible="state in ['sold', 'cancel']" />

                    <button name="action_archive_property"
                        type="object"
                        string="Archive"
                        class="btn-secondary o_estate_btn o_estate_btn_archive"
                        invisible="not active" />

                    <button name="action_unarchive_property"
                        type="object"
                        string="Unarchive"
                        class="btn-secondary o_estate_btn o_estate_btn_unarchive"
                        invisible="active" />

                    <button name="action_ai_recommend_offer"
                        type="object"
                        string="AI Recommend Offer"
                        class="btn-secondary o_estate_btn o_estate_btn_ai"
                        invisible="offer_count == 0" />

                    <field name="state" widget="statusbar" statusbar_visible="new,offer,sold,cancel" />
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object"
                            name="action_view_offers"
                            class="oe_stat_button o_estate_btn o_estate_btn_stat">
                            <field name="offer_count" widget="statinfo" string="Offers" />
                        </button>
                    </div>

                    <group>
                        <group>
                            <field name="name" />
                            <field name="property_type_id" />
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" />
                            <field name="salesperson_id" />
                            <field name="buyer_id" readonly="1" />
                            <field name="availability_date" />
                        </group>
                        <group>
                            <field name="expected_price" widget="monetary" options="{'currency_field': 'currency_id'}" />
                            <field name="selling_price" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}" />
                            <field name="best_price" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}" />
                            <field name="living_area" />
                            <field name="garden_area" />
                            <field name="total_area" readonly="1" />
                            <field name="currency_id" invisible="1" />
                            <field name="company_id" groups="base.group_multi_company" />
                            <field name="active" />
                        </group>
                    </group>
                    <group>
                        <field name="description" />
                    </group>

                    <separator string="AI Insights" />
                    <div class="o_estate_ai_panel">
                        <div class="o_estate_ai_panel_header">
                            <div class="o_estate_ai_title_block">
                                <h3>Offer Intelligence</h3>
                                <span class="text-muted">AI recommendation snapshot for this property</span>
                            </div>
                            <button name="action_ai_recommend_offer"
                                type="object"
                                string="Run AI Analysis"
                                class="btn btn-primary o_estate_btn o_estate_btn_ai_main"
                                invisible="offer_count == 0" />
                        </div>
                        <div class="o_estate_ai_metrics">
                            <div class="o_estate_ai_metric">
                                <span class="o_estate_ai_metric_label">Recommended Offer</span>
                                <field name="ai_recommended_offer_id" readonly="1" nolabel="1" />
                            </div>
                            <div class="o_estate_ai_metric">
                                <span class="o_estate_ai_metric_label">Confidence</span>
                                <field name="ai_recommendation_confidence" readonly="1" nolabel="1" widget="percentage" />
                            </div>
                            <div class="o_estate_ai_metric">
                                <span class="o_estate_ai_metric_label">Provider</span>
                                <field name="ai_provider" readonly="1" nolabel="1" />
                            </div>
                            <div class="o_estate_ai_metric">
                                <span class="o_estate_ai_metric_label">Last Analysis</span>
                                <field name="ai_last_analysis_at" readonly="1" nolabel="1" />
                            </div>
                        </div>
                        <div class="o_estate_ai_reasoning">
                            <label for="ai_recommendation_text" class="o_estate_ai_metric_label">Recommendation Note</label>
                            <field name="ai_recommendation_text" readonly="1" nolabel="1" placeholder="No recommendation yet. Run AI analysis after receiving offers." />
                        </div>
                    </div>

                    <notebook>
                        <page string="Offers">
                            <field name="offer_ids" context="{'default_property_id': id}">
                                <tree editable="bottom"
                                    create="1"
                                    delete="0"
                                    class="o_estate_offer_inline_tree"
                                    decoration-success="state == 'accepted'"
                                    decoration-muted="state == 'refused'">
                                    <field name="company_id" invisible="1" />
                                    <field name="price" />
                                    <field name="partner_id" />
                                    <field name="validity" />
                                    <field name="deadline" />
                                    <field name="state" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>
</odoo>
