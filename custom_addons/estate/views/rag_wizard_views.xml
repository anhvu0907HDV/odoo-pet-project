<odoo>
    <record id="view_estate_rag_ask_wizard_form" model="ir.ui.view">
        <field name="name">estate.rag.ask.wizard.form</field>
        <field name="model">estate.rag.ask.wizard</field>
        <field name="arch" type="xml">
            <form string="Ask AI (RAG)" class="o_estate_report_wizard_form">
                <sheet>
                    <div class="o_estate_report_intro">
                        <h2>Ask AI (RAG)</h2>
                        <p class="text-muted mb-0">
                            Ask questions grounded in this property’s data. If you recently changed offers or description, click “Refresh knowledge”.
                        </p>
                    </div>

                    <group>
                        <group>
                            <field name="property_id" readonly="1" />
                            <field name="auto_index" />
                        </group>
                        <group>
                            <field name="top_k" groups="base.group_system" />
                            <field name="indexed_chunk_count" readonly="1" />
                            <field name="last_indexed_at" readonly="1" />
                        </group>
                    </group>

                    <notebook>
                        <page string="Question">
                            <group>
                                <field name="question" placeholder="Examples: Summarize current status. Which offer is highest and why? Any urgent deadlines?" />
                            </group>
                        </page>
                        <page string="Answer">
                            <group>
                                <field name="answer_html" readonly="1" widget="html" placeholder="Answer will appear here after asking." />
                            </group>
                        </page>
                        <page string="Sources" invisible="sources_html == False">
                            <group>
                                <field name="sources_html" readonly="1" widget="html" />
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button string="Refresh knowledge" type="object" name="action_index" class="btn-secondary" />
                    <button string="Ask" type="object" name="action_ask" class="btn-primary" />
                    <button string="Close" special="cancel" class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_estate_rag_ask_wizard" model="ir.actions.act_window">
        <field name="name">Ask AI (RAG)</field>
        <field name="res_model">estate.rag.ask.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_property_id': active_id}</field>
    </record>
</odoo>
